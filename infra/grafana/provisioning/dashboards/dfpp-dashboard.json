{
  "annotations": { "list": [] },
  "editable": true,
  "title": "DFPP · Distributed Processing",
  "tags": ["dfpp", "kafka", "workers"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Processed (total)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(dfpp_jobs_processed_total)" }]
    },
    {
      "type": "stat",
      "title": "Failed (total)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "sum(dfpp_jobs_failed_total)" }]
    },
    {
      "type": "stat",
      "title": "Dead-lettered",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "sum(dfpp_jobs_deadlettered_total)" }]
    },
    {
      "type": "stat",
      "title": "Active workers",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "sum(dfpp_workers_active)" }]
    },
    {
      "type": "timeseries",
      "title": "Processing throughput (rate/s)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "targets": [
        { "expr": "rate(dfpp_jobs_processed_total[1m])", "legendFormat": "processed" },
        { "expr": "rate(dfpp_jobs_failed_total[1m])", "legendFormat": "failed" },
        { "expr": "rate(dfpp_jobs_retried_total[1m])", "legendFormat": "retried" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Job processing duration (p95)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(dfpp_jobs_processing_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Kafka consumer lag (processing-workers)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_records_lag_max",
          "legendFormat": "lag"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
